; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="PULSE_DeathRace"
config/description="3D car combat racing — Kenney base + DeathRace modes"
run/main_scene="res://scenes/Setup.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(1, 1, 1, 0)
boot_splash/image="res://splash-screen.png"
config/icon="res://icon.png"

[autoload]

MatchConfig="*res://scripts/autoload/MatchConfig.gd"
RenderScaler="*res://scripts/autoload/RenderScaler.gd"
FrameSpikeProfiler="*res://scripts/debug/FrameSpikeProfiler.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[filesystem]

import/fbx/enabled=false

